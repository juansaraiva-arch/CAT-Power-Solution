# ══════════════════════════════════════════════════════════════
# CAT Power Solution — Environment Variables
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env al repositorio
# En producción: todos estos valores vienen de Azure Key Vault
# ══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
APP_VERSION=3.2.0
LOG_LEVEL=INFO

# ── Entra ID — IT CAT configura estos valores ─────────────────
ENTRA_TENANT_ID=caterpillar.com
ENTRA_APP_CLIENT_ID=           # IT provee al crear la App Registration

# ── Database — IT CAT configura este valor ────────────────────
DATABASE_URL=                  # postgresql://cps_app:{pwd}@{host}:5432/cat_power_solution?sslmode=require

# ── Azure Blob Storage — IT CAT configura ─────────────────────
AZURE_STORAGE_ACCOUNT_NAME=    # IT provee
AZURE_STORAGE_CONTAINER_PDFS=cat-power-solution-pdfs
AZURE_STORAGE_KEY=             # vacío en producción (usa Managed Identity)

# ── Anthropic — Francisco Saraiva gestiona ────────────────────
ANTHROPIC_API_KEY=             # contactar francisco.saraiva@cat.com

# ── CORS — actualizar con el dominio real asignado por IT ─────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Producción: https://cat-power-solution.cat.com

# ── Feature Flags ─────────────────────────────────────────────
REQUIRE_AUTH=true              # false solo para desarrollo local
ENABLE_DB_PERSISTENCE=false    # false hasta que IT configure PostgreSQL
ENABLE_PDF_GENERATION=true

# ── Rate Limiting ─────────────────────────────────────────────
MAX_REQUESTS_PER_HOUR=100
MAX_REQUESTS_DEMO_PER_HOUR=20
